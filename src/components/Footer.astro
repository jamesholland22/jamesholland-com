</footer>

<style>
  .site-footer {
    margin-top: var(--space-32);
    padding-block: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .site-footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .site-footer__copy {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .site-footer__right {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .site-footer__socials {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .social-link {
    display: flex;
    align-items: center;
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
    opacity: 0.6;
  }

  .social-link:hover {
    color: var(--color-text);
    opacity: 1;
  }

  .site-footer__email {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .site-footer__email:hover {
    color: var(--color-text);
  }
</style>
