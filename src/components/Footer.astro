---
const year = new Date().getFullYear();

const links = [
  { href: 'https://linkedin.com/in/jamesholland', label: 'LinkedIn' },
  { href: 'mailto:hello@jamesholland.com', label: 'Email' },
];
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <p class="site-footer__copy">
      &copy; {year} James Holland
    </p>
    <nav class="site-footer__links" aria-label="Footer links">
      {links.map(({ href, label }) => (
        <a href={href} class="site-footer__link">
          {label}
        </a>
      ))}
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-32);
    padding-block: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .site-footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .site-footer__copy {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .site-footer__links {
    display: flex;
    gap: var(--space-4);
  }

  .site-footer__link {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .site-footer__link:hover {
    color: var(--color-text);
  }
</style>
