---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

type StickerColor = 'yellow' | 'pink' | 'green' | 'blue' | 'orange';
type StickerName = 'star' | 'sparkle' | 'burst' | 'arrow' | 'check' | 'circle' | 'lightning' | 'heart' | 'plus' | 'wave' | 'empire-state' | 'liberty' | 'big-ben' | 'uk-flag' | 'laptop' | 'pencil';
type StickerSize = 'sm' | 'md' | 'lg';

interface Props {
  /** Pick a built-in SVG sticker by name */
  name?: StickerName;
  /** Or supply an imported PNG/image (import myImg from '…/stickers/x.png') */
  src?: ImageMetadata;
  /** Or paste any emoji — renders via OpenMoji CDN */
  emoji?: string;
  color?: StickerColor;
  size?: StickerSize;
  rotate?: number;
  /** Accessible label — omit for purely decorative use */
  alt?: string;
}

const { name, src, emoji, color = 'yellow', size = 'md', rotate, alt = '' } = Astro.props;

// ─── OpenMoji helper ─────────────────────────────────────────────────────────
// Converts an emoji character to its jsDelivr-hosted OpenMoji SVG URL.
// Handles single codepoints, multi-codepoint sequences (flags, ZWJ), and
// variation selectors — all included verbatim as OpenMoji expects them.
function emojiToOpenMojiUrl(e: string): string {
  const codes = [...e].map(char => char.codePointAt(0)!.toString(16).toUpperCase());
  return `https://cdn.jsdelivr.net/npm/openmoji@16.0.0/color/svg/${codes.join('-')}.svg`;
}

const emojiUrl = emoji ? emojiToOpenMojiUrl(emoji) : null;

// ─── SVG library ────────────────────────────────────────────────────────────
// All shapes use currentColor so the `color` prop drives the tint.
// filled: true  → svg fill="currentColor" stroke="none"
// filled: false → svg fill="none"        stroke="currentColor"

type SvgDef = { markup: string; filled: boolean; raw?: boolean };

const svgLibrary: Record<StickerName, SvgDef> = {
  star: {
    filled: true,
    markup: '<polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>',
  },
  sparkle: {
    filled: true,
    markup: '<path d="M12 2L13.8 10.2L22 12L13.8 13.8L12 22L10.2 13.8L2 12L10.2 10.2Z"/>',
  },
  burst: {
    filled: true,
    markup: '<path d="M12 2L13.5 8.5L19.07 4.93L16 10.5L22 12L16 13.5L19.07 19.07L13.5 15.5L12 22L10.5 15.5L4.93 19.07L8 13.5L2 12L8 10.5L4.93 4.93L10.5 8.5Z"/>',
  },
  lightning: {
    filled: true,
    markup: '<path d="M13 2L4 14H11V22L20 10H13L13 2Z"/>',
  },
  heart: {
    filled: true,
    markup: '<path d="M12 21C12 21 3 14.5 3 9a4.978 4.978 0 0 1 9-3 4.978 4.978 0 0 1 9 3c0 5.5-9 12-9 12Z"/>',
  },
  arrow: {
    filled: false,
    markup: '<line x1="5" y1="12" x2="19" y2="12" stroke-width="2.5" stroke-linecap="round"/><polyline points="13,6 19,12 13,18" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>',
  },
  check: {
    filled: false,
    markup: '<polyline points="4,13 9,18 20,7" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>',
  },
  circle: {
    filled: false,
    markup: '<circle cx="12" cy="12" r="9" stroke-width="2.5"/>',
  },
  plus: {
    filled: false,
    markup: '<line x1="12" y1="5" x2="12" y2="19" stroke-width="3" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke-width="3" stroke-linecap="round"/>',
  },
  wave: {
    filled: false,
    markup: '<path d="M2 12 C5 8 7 8 10 12 C13 16 15 16 18 12 C21 8 22 8 23 10" stroke-width="2.5" stroke-linecap="round"/>',
  },
  // ─── New stickers ───────────────────────────────────────
  'empire-state': {
    filled: true,
    markup: '<path d="M12 1L12.5 1L12.5 3.5L13.5 3.5L13.5 5.5L14.5 5.5L14.5 8.5L16 8.5L16 11L17.5 11L17.5 22L6.5 22L6.5 11L8 11L8 8.5L9.5 8.5L9.5 5.5L10.5 5.5L10.5 3.5L11.5 3.5L11.5 1Z"/>',
  },
  liberty: {
    filled: true,
    markup: '<polygon points="12,2 11.4,7 12.6,7"/><polygon points="10,3 9.3,7 10.7,7"/><polygon points="14,3 13.3,7 14.7,7"/><polygon points="9,4.5 8.3,7 9.7,7"/><polygon points="15,4.5 14.3,7 15.7,7"/><ellipse cx="12" cy="9" rx="2" ry="2.5"/><path d="M10 11.5L14 11.5L15.5 22L8.5 22Z"/><path d="M14 8.5L19 5.5L19.5 7L15 10Z"/><path d="M19 5.5L20.5 3.5L21.5 5L20 7L19.5 7Z"/>',
  },
  'big-ben': {
    filled: true,
    markup: '<polygon points="12,1 13.5,5 10.5,5"/><rect x="10" y="5" width="4" height="3" rx="0.5"/><rect x="9" y="8" width="6" height="7" rx="0.5"/><circle cx="12" cy="11.5" r="2.5" fill="white"/><line x1="12" y1="11.5" x2="12" y2="9.5" stroke="currentColor" stroke-width="0.8"/><line x1="12" y1="11.5" x2="13.5" y2="11.5" stroke="currentColor" stroke-width="0.8"/><rect x="10.5" y="15" width="3" height="4"/><rect x="8.5" y="19" width="7" height="4" rx="1"/>',
  },
  'uk-flag': {
    filled: false,
    raw: true,
    markup: '<rect width="24" height="24" fill="#012169" rx="3"/><line x1="0" y1="0" x2="24" y2="24" stroke="white" stroke-width="7"/><line x1="24" y1="0" x2="0" y2="24" stroke="white" stroke-width="7"/><line x1="0" y1="0" x2="24" y2="24" stroke="#C8102E" stroke-width="4.5"/><line x1="24" y1="0" x2="0" y2="24" stroke="#C8102E" stroke-width="4.5"/><rect x="0" y="9.5" width="24" height="5" fill="white"/><rect x="9.5" y="0" width="5" height="24" fill="white"/><rect x="0" y="10.5" width="24" height="3" fill="#C8102E"/><rect x="10.5" y="0" width="3" height="24" fill="#C8102E"/>',
  },
  laptop: {
    filled: true,
    markup: '<rect x="3" y="2" width="18" height="14" rx="2"/><rect x="4.5" y="3.5" width="15" height="11" rx="1" fill="white"/><rect x="2" y="16" width="20" height="1.5"/><path d="M1 17.5L23 17.5L22 21.5C22 22.5 21 23 20 23L4 23C3 23 2 22.5 2 21.5Z"/><rect x="8.5" y="19.5" width="7" height="3" rx="1.5" fill="white"/>',
  },
  pencil: {
    filled: true,
    markup: '<path d="M19 1L23 5L8 22L1 22L5 18Z"/><path d="M2 22L5 18L8 22Z" fill="white"/><line x1="18" y1="2" x2="22" y2="6" stroke="white" stroke-width="2"/>',
  },
};

// ─── Props resolution ────────────────────────────────────────────────────────
const defaultRotations: Partial<Record<StickerName, number>> = {
  star: -8, sparkle: 12, burst: 10,
  arrow: -3, check: -5, circle: 3,
  lightning: -6, heart: -8, plus: 5, wave: -2,
  'empire-state': -3, liberty: 5, 'big-ben': -4,
  'uk-flag': -8, laptop: 5, pencil: 0,
};

const finalRotate = rotate ?? (name ? (defaultRotations[name] ?? 0) : emoji ? -6 : 0);

const sizeMap: Record<StickerSize, string> = {
  sm: '1.25em',
  md: '1.75em',
  lg: '2.75em',
};

const colorMap: Record<StickerColor, string> = {
  yellow: 'var(--sticker-yellow)',
  pink:   'var(--sticker-pink)',
  green:  'var(--sticker-green)',
  blue:   'var(--sticker-blue)',
  orange: 'var(--sticker-orange)',
};

const svgDef = name ? svgLibrary[name] : null;
---

<!-- SVG stickers use 8-directional drop-shadow (crisp vector edges).
     Raster stickers (emoji, PNG) use the Gaussian blur SVG filter (smooth on pixels). -->
<span
  class:list={['g-sticker', (src || emojiUrl) ? 'g-sticker--raster' : 'g-sticker--vector']}
  style={`--g-color:${colorMap[color]};--g-size:${sizeMap[size]};--g-rotate:${finalRotate}deg`}
  aria-hidden={alt ? undefined : 'true'}
  role={alt ? 'img' : undefined}
  aria-label={alt || undefined}
>
  {svgDef && svgDef.raw && (
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" set:html={svgDef.markup} />
  )}
  {svgDef && !svgDef.raw && (
    <svg
      viewBox="0 0 24 24"
      fill={svgDef.filled ? 'currentColor' : 'none'}
      stroke={svgDef.filled ? 'none' : 'currentColor'}
      xmlns="http://www.w3.org/2000/svg"
      set:html={svgDef.markup}
    />
  )}
  {src && (
    <Image
      src={src}
      alt={alt}
      width={96}
      height={96}
      class="g-sticker__img"
    />
  )}
  {emojiUrl && (
    <img src={emojiUrl} alt={alt || emoji} class="g-sticker__img" loading="lazy" />
  )}
</span>

<style>
  .g-sticker {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    /* Padding gives the outline room to breathe without being clipped */
    width: calc(var(--g-size) * 1.3);
    height: calc(var(--g-size) * 1.3);
    padding: calc(var(--g-size) * 0.15);
    /* Depth shadow — shared by both outline techniques below */
    --g-shadow: drop-shadow(0 5px 5px rgba(0, 0, 0, 0.18));
    color: var(--g-color);
    transform: rotate(var(--g-rotate));
    transform-origin: center;
    vertical-align: middle;
    position: relative;
    top: -0.05em;
    flex-shrink: 0;
    transition: transform var(--transition-fast, 150ms ease);
    cursor: default;
    user-select: none;
    /* Promote to GPU compositing layer so filter is pre-baked and
       hover transforms animate without triggering filter recalculation */
    will-change: transform;
  }

  /* SVG stickers: 8-directional drop-shadow traces clean vector edges */
  .g-sticker--vector {
    filter:
      drop-shadow(0     3px   0 #fff)
      drop-shadow(0    -3px   0 #fff)
      drop-shadow(3px   0     0 #fff)
      drop-shadow(-3px  0     0 #fff)
      drop-shadow(2.5px  2.5px  0 #fff)
      drop-shadow(-2.5px 2.5px  0 #fff)
      drop-shadow(2.5px -2.5px  0 #fff)
      drop-shadow(-2.5px -2.5px 0 #fff)
      var(--g-shadow);
  }

  /* Raster stickers (emoji, PNG): Gaussian blur traces smooth pixel shapes */
  .g-sticker--raster {
    filter: url(#sticker-outline) var(--g-shadow);
  }

  .g-sticker:hover {
    transform: rotate(calc(var(--g-rotate) * -0.6)) scale(1.15);
  }

  .g-sticker svg {
    width: 100%;
    height: 100%;
    display: block;
    flex-shrink: 0;
  }

  /* PNG / raster images */
  .g-sticker__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
</style>
