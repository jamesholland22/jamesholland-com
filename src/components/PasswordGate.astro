---
interface Props {
  enabled: boolean;
}
const { enabled } = Astro.props;
---

{enabled ? (
  <>
    <div id="pg-gate">
      <div class="pg-form">
        <p class="pg-label">This case study is password protected</p>
        <p class="pg-hint">Enter the password to view the full work.</p>
        <div class="pg-inputs">
          <input
            type="password"
            id="pg-input"
            placeholder="Password"
            autocomplete="current-password"
          />
          <button id="pg-submit">Unlock</button>
        </div>
        <p id="pg-error" class="pg-error" hidden>Incorrect password — try again.</p>
      </div>
    </div>
    <div id="pg-content" hidden>
      <slot />
    </div>
  </>
) : (
  <slot />
)}

<script>
  // Change this to your preferred password
  const PASSWORD = 'portfolio2024';
  const KEY = 'jh_unlocked';

  const gate = document.getElementById('pg-gate');
  const content = document.getElementById('pg-content');
  const input = document.getElementById('pg-input') as HTMLInputElement | null;
  const submit = document.getElementById('pg-submit');
  const error = document.getElementById('pg-error');

  if (gate && content) {
    // Already unlocked from a previous visit
    if (localStorage.getItem(KEY) === '1') {
      gate.hidden = true;
      content.hidden = false;
    }

    submit?.addEventListener('click', () => {
      if (input?.value === PASSWORD) {
        localStorage.setItem(KEY, '1');
        gate.hidden = true;
        content.hidden = false;
      } else {
        if (error) error.hidden = false;
        if (input) { input.value = ''; input.focus(); }
      }
    });

    input?.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') submit?.click();
    });
  }
</script>

<style>
  /* Ensure the hidden attribute always wins over display rules */
  #pg-gate[hidden],
  #pg-content[hidden] {
    display: none !important;
  }

  #pg-gate {
    display: flex;
    justify-content: center;
    padding: var(--space-24) var(--space-8);
  }

  .pg-form {
    text-align: center;
    max-width: 24rem;
  }

  .pg-label {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .pg-hint {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
  }

  .pg-inputs {
    display: flex;
    gap: var(--space-3);
  }

  #pg-input {
    flex: 1;
    padding: 0.65em 1em;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  #pg-input:focus {
    outline: 2px solid var(--color-text);
    outline-offset: 1px;
  }

  #pg-submit {
    padding: 0.65em 1.4em;
    background: var(--color-text);
    color: var(--color-bg);
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    cursor: pointer;
    transition: opacity var(--transition-fast);
    white-space: nowrap;
  }

  #pg-submit:hover {
    opacity: 0.8;
  }

  .pg-error {
    font-size: var(--text-xs);
    color: #e03131;
    margin-top: var(--space-4);
  }
</style>
