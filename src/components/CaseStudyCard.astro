---
import { Image } from 'astro:assets';

interface Props {
  slug: string;
  title: string;
  client: string;
  year: number;
  tags: string[];
  coverImage: ImageMetadata;
  summary: string;
  featured?: boolean;
}

const { slug, title, client, year, tags, coverImage, summary, featured = false } = Astro.props;
---

<a href={`/work/${slug}`} class:list={['card', { 'card--featured': featured }]}>
  <div class="card__image-wrap">
    <Image
      src={coverImage}
      alt={title}
      class="card__image"
      widths={[480, 800]}
      sizes="(min-width: 72rem) 500px, (min-width: 48rem) 45vw, 90vw"
    />
  </div>
  <div class="card__body">
    <div class="card__meta">
      <span class="card__client">{client}</span>
      <span class="card__year">{year}</span>
    </div>
    <h2 class="card__title">{title}</h2>
    <p class="card__summary">{summary}</p>
    <div class="card__tags">
      {tags.slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}
    </div>
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    color: inherit;
    text-decoration: none;
    border-radius: var(--radius-lg);
    transition: transform var(--transition-base);
  }

  .card:hover {
    transform: translateY(-3px);
  }

  .card:hover .card__image {
    transform: scale(1.03);
  }

  .card__image-wrap {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-surface);
    aspect-ratio: 16 / 9;
  }

  .card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .card__meta::before {
    display: none;
  }

  .card__client {
    color: var(--color-text-muted);
  }

  .card__year {
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .card__title {
    font-size: var(--text-xl);
    line-height: 1.25;
    transition: opacity var(--transition-fast);
  }

  .card:hover .card__title {
    opacity: 0.7;
  }

  .card__summary {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-1);
  }

  .tag {
    font-size: var(--text-xs);
    font-weight: 500;
    padding: 0.2em 0.65em;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text-muted);
    background: var(--color-surface);
  }

  /* Featured card spans full width in the grid */
  .card--featured {
    grid-column: 1 / -1;
    flex-direction: row;
    align-items: flex-start;
    gap: var(--space-8);
  }

  .card--featured .card__image-wrap {
    flex: 1 1 55%;
    aspect-ratio: 16 / 9;
  }

  .card--featured .card__body {
    flex: 1 1 40%;
    padding-top: var(--space-4);
    gap: var(--space-3);
  }

  .card--featured .card__title {
    font-size: var(--text-2xl);
  }

  .card--featured .card__summary {
    -webkit-line-clamp: 3;
    font-size: var(--text-base);
  }

  @media (max-width: 48rem) {
    .card--featured {
      flex-direction: column;
    }

    .card--featured .card__image-wrap {
      flex: none;
      width: 100%;
    }
  }
</style>
