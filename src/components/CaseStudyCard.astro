---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

interface Props {
  slug: string;
  title: string;
  client: string;
  year: number;
  tags: string[];
  coverImage?: string;
  summary: string;
  featured?: boolean;
}

const { slug, title, client, year, tags, coverImage, summary } = Astro.props;
---

<a href={`${base}/work/${slug}`} class="card">
  <div class="card__image-wrap">
    {coverImage ? (
      <img
        src={coverImage}
        alt={title}
        class="card__image"
        loading="lazy"
        transition:name={`cover-${slug}`}
      />
    ) : (
      <div class="card__image card__image--placeholder" aria-hidden="true"></div>
    )}
  </div>
  <div class="card__body">
    <div class="card__meta">
      <span class="card__client">{client}</span>
      <span class="card__sep" aria-hidden="true">·</span>
      <span class="card__year">{year}</span>
    </div>
    <h2 class="card__title" transition:name={`title-${slug}`}>{title}</h2>
    <p class="card__summary">{summary}</p>
    <div class="card__tags">
      {tags.slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}
    </div>
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    color: inherit;
    text-decoration: none;
  }

  /* Image zoom on hover — only the image moves, nothing else */
  .card__image-wrap {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-surface);
    aspect-ratio: 16 / 9;
  }

  .card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease;
    display: block;
  }

  .card__image--placeholder {
    background: var(--color-border);
  }

  .card:hover .card__image {
    transform: scale(1.05);
  }

  .card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .card__sep {
    opacity: 0.4;
  }

  .card__title {
    font-size: var(--text-lg);
    line-height: 1.3;
    transition: opacity var(--transition-fast);
  }

  .card:hover .card__title {
    opacity: 0.65;
  }

  .card__summary {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-1);
  }

  .tag {
    font-size: var(--text-xs);
    font-weight: 500;
    padding: 0.2em 0.65em;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text-muted);
    background: var(--color-surface);
  }
</style>
