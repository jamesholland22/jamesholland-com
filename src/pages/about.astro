---
import BaseLayout from '../layouts/BaseLayout.astro';
import GraphicSticker from '../components/GraphicSticker.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const links = [
  { label: 'LinkedIn',  href: 'https://linkedin.com/in/jamesholland' },
  { label: 'Bluesky',   href: 'https://bsky.app/profile/jamesholland.com' },
  { label: 'Threads',   href: 'https://www.threads.net/@jamesholland' },
  { label: 'X',         href: 'https://x.com/jamesholland' },
];
---

<BaseLayout
  title="About"
  description="I live in New York, ordering bagels with a British accent for over ten years."
>
  <section class="about">
    <div class="container container--narrow">

      <h1 class="about__heading">
        I live in New York, ordering bagels with a British accent for over ten years.
        <GraphicSticker name="heart" color="pink" size="lg" rotate={-8} />
      </h1>

      <div class="about__links">
        {links.map(link => (
          <a href={link.href} class="about__link" target="_blank" rel="noopener noreferrer">
            {link.label} →
          </a>
        ))}
      </div>

      <div class="about__work-link">
        <a href={`${base}/`}>See my work ↓</a>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .about {
    padding-top: var(--space-24);
    padding-bottom: var(--space-32);
    min-height: 70vh;
    display: flex;
    align-items: center;
  }

  .about__heading {
    font-size: var(--text-3xl);
    line-height: 1.2;
    max-width: 18ch;
    margin-bottom: var(--space-12);
    letter-spacing: -0.03em;
  }

  .about__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-8);
    margin-bottom: var(--space-12);
  }

  .about__link {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .about__link:hover {
    color: var(--color-text);
  }

  .about__work-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
  }

  .about__work-link a {
    transition: color var(--transition-fast);
  }

  .about__work-link a:hover {
    color: var(--color-text);
  }
</style>
