---
import BaseLayout from './BaseLayout.astro';
import PasswordGate from '../components/PasswordGate.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

interface NavEntry {
  title: string;
  slug: string;
  client: string;
}

interface Props {
  title: string;
  client: string;
  year: number;
  tags: string[];
  coverImage?: string;
  summary: string;
  protected?: boolean;
  category?: string;
  prev?: NavEntry | null;
  next?: NavEntry | null;
}

const {
  title, client, year, tags, coverImage, summary,
  protected: isProtected = false,
  category,
  prev,
  next,
} = Astro.props;
---

<BaseLayout
  title={`${title} — ${client}`}
  description={summary}
  ogType="article"
>
  <article class="case-study">
    <!-- Hero — always visible -->
    <div class="case-study__hero">
      <div class="container">
        <div class="case-study__meta">
          <a href={`${base}/`} class="case-study__back">← All work</a>
          <div class="case-study__tags">
            {tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        </div>
        <h1 class="case-study__title" transition:name={`title-${Astro.params.slug}`}>{title}</h1>
        <p class="case-study__summary">{summary}</p>
        <p class="case-study__byline">{client} &middot; {year}</p>
      </div>
    </div>

    <!-- Cover image + body — gated if protected -->
    <PasswordGate enabled={isProtected}>
      {coverImage && (
        <div class="case-study__cover-wrap">
          <div class="container">
            <img
              src={coverImage}
              alt={`Cover image for ${title}`}
              class="case-study__cover"
              loading="lazy"
              transition:name={`cover-${Astro.params.slug}`}
            />
          </div>
        </div>
      )}

      <div class="container container--narrow case-study__body">
        <div class="prose">
          <slot />
        </div>
      </div>
    </PasswordGate>

    <!-- Footer nav -->
    <div class="container case-study__footer-nav">
      <a href={`${base}/`} class="case-study__back case-study__back--bottom">← All work</a>

      {(prev || next) && (
        <nav class="case-study__pagination" aria-label="More in this category">
          {category && <p class="pagination__label">More in {category}</p>}
          <div class="pagination__row">
            <div class="pagination__slot pagination__slot--prev">
              {prev && (
                <a href={`${base}/work/${prev.slug}`} class="pagination__link pagination__link--prev">
                  <span class="pagination__dir">← Previous</span>
                  <span class="pagination__title">{prev.title}</span>
                  <span class="pagination__client">{prev.client}</span>
                </a>
              )}
            </div>
            <div class="pagination__slot pagination__slot--next">
              {next && (
                <a href={`${base}/work/${next.slug}`} class="pagination__link pagination__link--next">
                  <span class="pagination__dir">Next →</span>
                  <span class="pagination__title">{next.title}</span>
                  <span class="pagination__client">{next.client}</span>
                </a>
              )}
            </div>
          </div>
        </nav>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .case-study__hero {
    padding-top: var(--space-16);
    padding-bottom: var(--space-12);
  }

  .case-study__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-8);
  }

  .case-study__back {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .case-study__back:hover {
    color: var(--color-text);
  }

  .case-study__tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .tag {
    font-size: var(--text-xs);
    font-weight: 500;
    padding: 0.25em 0.75em;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text-muted);
    background: var(--color-surface);
  }

  .case-study__title {
    font-size: var(--text-3xl);
    max-width: 22ch;
    margin-bottom: var(--space-6);
  }

  .case-study__summary {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 56ch;
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }

  .case-study__byline {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .case-study__cover-wrap {
    margin-bottom: var(--space-16);
  }

  .case-study__cover {
    width: 100%;
    border-radius: var(--radius-lg);
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .case-study__body {
    margin-bottom: var(--space-24);
  }

  .case-study__footer-nav {
    padding-top: var(--space-8);
    padding-bottom: var(--space-16);
  }

  .case-study__back--bottom {
    display: inline-block;
    margin-bottom: var(--space-12);
  }

  /* ── Prev / Next pagination ── */
  .case-study__pagination {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-8);
  }

  .pagination__label {
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .pagination__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .pagination__slot--next {
    display: flex;
    justify-content: flex-end;
  }

  .pagination__link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    max-width: 28ch;
    padding: var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    transition: border-color var(--transition-fast), background var(--transition-fast);
    text-decoration: none;
  }

  .pagination__link:hover {
    border-color: var(--color-text-muted);
    background: var(--color-bg);
  }

  .pagination__link--next {
    text-align: right;
    align-items: flex-end;
  }

  .pagination__dir {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .pagination__title {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
  }

  .pagination__client {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  @media (max-width: 480px) {
    .pagination__row {
      grid-template-columns: 1fr;
    }
    .pagination__slot--next {
      justify-content: flex-start;
    }
    .pagination__link--next {
      text-align: left;
      align-items: flex-start;
    }
  }
</style>
